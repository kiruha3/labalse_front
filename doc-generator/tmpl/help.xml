<?xml version="1.0" encoding="UTF-8"?>
<template version="100" format="A4l" margin-top="10mm" margin-right="10mm" margin-bottom="10mm" margin-left="10mm">
    <styles>
        <style name="tab-header">
            <attr group="font" name="font-size">12pt</attr>
            <attr group="font" name="bold"/>
            <attr group="text" name="align">center</attr>
        </style>
    </styles>
    <main-text>
        <block pagebreak="before" font-size="12pt">
            <p>общий синтаксис для вставки значения переменных: <mark color="#444444"><hl color="#ffff00">&lt;var </hl><hl color="#ffffff">name</hl><hl color="#80ff00">="имя_переменной"</hl><hl color="#ffff00">/></hl></mark>
            </p>
            <table>
                <colpar>
                    <col border="thin solid #000000" width="70mm"/>
                    <col border="thin solid #000000" width="20mm"/>
                    <col border="thin solid #000000" width="90mm"/>
                    <col border="thin solid #000000" width="90mm"/>
                </colpar>
                <tr>
                    <td style="tab-header">
                        Имя_переменной
                    </td>
                    <td style="tab-header">
                        Тип
                    </td>
                    <td style="tab-header">
                        Описание
                    </td>
                    <td style="tab-header">
                        Значение
                    </td>
                </tr>
                <dyna-con name="/">
                    <element name="var">
                        <tr>
                            <td>
                                <element-attr name="name"/>
                            </td>
                            <td>
                                <element-attr name="type"/>
                            </td>
                            <td>
                                <element-attr name="descr"/>
                            </td>
                            <td>
                                <sub-var name="."/>
                            </td>
                        </tr>
                    </element>
                </dyna-con>
            </table>
        </block>
    </main-text>
</template>